#!/bin/sh /etc/rc.common

START=95
USE_PROCD=1

STATE_DIR="/etc/dns-smart-routing"
LOCKFILE="/tmp/dns-smart-routing.lock"
MARKER="$STATE_DIR/.installed"

# Atomic dnsmasq.conf integration — no direct append, no duplicates
_dnsmasq_conf_add() {
    local line="servers-file=/tmp/dnsmasq_dynamic_servers.conf"
    local conf="/etc/dnsmasq.conf"
    [ ! -f "$conf" ] && return 0
    grep -q "$line" "$conf" && return 0  # Already present — skip entirely

    local tmp="${conf}.tmp"
    grep -v "servers-file=/tmp/dnsmasq_dynamic_servers.conf" "$conf" > "$tmp" 2>/dev/null \
        && printf '%s\n' "$line" >> "$tmp" 2>/dev/null \
        && mv "$tmp" "$conf" 2>/dev/null \
        || { rm -f "$tmp" 2>/dev/null; return 1; }
    return 0
}

# Marker-guarded cron — written exactly once, never duplicated
_cron_add() {
    [ -f "$MARKER" ] && return 0  # Already installed — skip unconditionally

    local entry="*/1 * * * * /usr/bin/dns_smart_probe.sh && /usr/bin/dns_smart_apply.sh"
    local crontab="/etc/crontabs/root"
    touch "$crontab" 2>/dev/null

    local tmp="${crontab}.tmp"
    grep -v "dns_smart_probe.sh" "$crontab" > "$tmp" 2>/dev/null \
        && printf '%s\n' "$entry" >> "$tmp" 2>/dev/null \
        && mv "$tmp" "$crontab" 2>/dev/null \
        || { rm -f "$tmp" 2>/dev/null; return 1; }

    touch "$MARKER" 2>/dev/null
    /etc/init.d/cron restart 2>/dev/null || true
}

_cron_remove() {
    local crontab="/etc/crontabs/root"
    [ ! -f "$crontab" ] && return
    grep -q "dns_smart_probe.sh" "$crontab" || return

    local tmp="${crontab}.tmp"
    grep -v "dns_smart_probe.sh" "$crontab" > "$tmp" 2>/dev/null \
        && mv "$tmp" "$crontab" 2>/dev/null \
        || rm -f "$tmp" 2>/dev/null

    rm -f "$MARKER" 2>/dev/null
    /etc/init.d/cron restart 2>/dev/null || true
}

start_service() {
    # ── BOOT SAFETY: clear stale lock unconditionally ─────────────────────────
    rm -f "$LOCKFILE" 2>/dev/null

    mkdir -p "$STATE_DIR" 2>/dev/null

    # ── STATE FILE: init if missing or corrupt ────────────────────────────────
    local sf="$STATE_DIR/state.json"
    local need_init=0
    [ ! -f "$sf" ] || [ ! -s "$sf" ] && need_init=1
    [ $need_init -eq 0 ] && ! jq -e . "$sf" >/dev/null 2>&1 && need_init=1

    if [ $need_init -eq 1 ]; then
        printf '{"state":"NORMAL","fail_count":0,"ok_count":0,"last_change":0,"last_fail_time":0,"pending_state":"","pending_count":0,"last_eval_result":-1,"last_eval_time":0}\n' \
            > "$sf" 2>/dev/null
    fi

    # ── DNSMASQ: ensure conf file exists and line added (max 1 restart) ───────
    touch /tmp/dnsmasq_dynamic_servers.conf 2>/dev/null
    local added=0
    _dnsmasq_conf_add && added=1
    # Only restart dnsmasq if the conf line was actually missing (added=1 means
    # it was absent before — _dnsmasq_conf_add returns 0 in both cases but
    # grep -q exits 0 when already present, so we track via an explicit flag)
    # Safer: check if grep found the line BEFORE calling add
    # We track this by re-reading result
    if grep -q "servers-file=/tmp/dnsmasq_dynamic_servers.conf" /etc/dnsmasq.conf 2>/dev/null; then
        # Line now present — restart only if it wasn't there before this boot
        # Use reload-marker to avoid double restart during install+start sequence
        local reload_marker="/tmp/dnsmasq-dns-smart-reloaded"
        if [ ! -f "$reload_marker" ]; then
            touch "$reload_marker" 2>/dev/null
            /etc/init.d/dnsmasq restart 2>/dev/null || true
        fi
    fi

    # ── CRON: install exactly once (marker-guarded) ───────────────────────────
    _cron_add
}

stop_service() {
    _cron_remove
    rm -f /tmp/dnsmasq-dns-smart-reloaded 2>/dev/null
}
